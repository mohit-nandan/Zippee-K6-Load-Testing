# Copy this file to .env and fill in real values
# NEVER commit .env to git — it contains secrets

# ===== STAGING =====
STAGING_BASE_URL=https://staging.zfwhospitality.in
STAGING_ADMIN_USER=your-staging-email
STAGING_ADMIN_PASS=your-staging-password
STAGING_CLICKPOST_API_KEY=your-staging-clickpost-key
STAGING_CLICKPOST_USERNAME=your-clickpost-username
STAGING_CLICKPOST_PASS=your-clickpost-password

# ===== PREPROD =====
PREPROD_BASE_URL=https://beta.zfwhospitality.in
PREPROD_ADMIN_USER=your-preprod-email
PREPROD_ADMIN_PASS=your-preprod-password
PREPROD_CLICKPOST_API_KEY=your-preprod-clickpost-key
PREPROD_CLICKPOST_USERNAME=your-clickpost-username
PREPROD_CLICKPOST_PASS=your-clickpost-password

# ===== PROD =====
PROD_BASE_URL=https://blaze.zippee.delivery
PROD_ADMIN_USER=your-prod-email
PROD_ADMIN_PASS=your-prod-password
PROD_CLICKPOST_API_KEY=your-prod-clickpost-key
PROD_CLICKPOST_USERNAME=your-clickpost-username
PROD_CLICKPOST_PASS=your-clickpost-password
PROD_X_API_KEY=your-x-api-key
